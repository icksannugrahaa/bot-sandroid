# OpenWA Bot Configuration
# Copy this file to .env and fill in your values

# Your OpenWA server URL (no trailing slash)
OPENWA_BASE_URL=http://localhost:2785

# API Key from your OpenWA dashboard
OPENWA_API_KEY=YOUR_API_KEY

# Session ID (the one you already created & registered)
OPENWA_SESSION_ID=YOUR_SESSION_ID

# Port this bot will listen on for webhooks
BOT_PORT=5000

# Encryption key for storing passwords & TOTP secrets
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Azure OpenAI Configuration (Optional, for AI chat)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview
