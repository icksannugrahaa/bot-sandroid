# OpenWA Bot Configuration
# Copy this file to .env and fill in your values

# Your OpenWA server URL (no trailing slash)
OPENWA_BASE_URL=http://localhost:2785

# API Key from your OpenWA dashboard
OPENWA_API_KEY=YOUR_API_KEY

# Session ID (the one you already created & registered)
OPENWA_SESSION_ID=YOUR_SESSION_ID

# Port this bot will listen on for webhooks
BOT_PORT=5000

# Bot's own WhatsApp phone number (without + or spaces, e.g. 628123456789)
# Required for group chat: bot only responds when @mentioned
BOT_PHONE=628123456789

# Bot's WhatsApp LID (Linked ID) — used for @mention detection in groups
# WhatsApp uses LID instead of phone numbers in @mentions
# To find yours: check bot logs when someone tags the bot, body will show @<LID>
BOT_LID=39656188063751

# Encryption key for storing passwords & TOTP secrets
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# GitHub Models API Configuration (Runs on Azure, guaranteed NOT blocked!)
GITHUB_TOKEN=your-github-personal-access-token

# Admin WhatsApp Chat IDs (Comma-separated, used for automation notifications)
ADMIN_CHAT_IDS=1234567890@c.us,0987654321@c.us
